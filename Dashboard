import os
import pandas as pd
import plotly.graph_objects as go
from dash import Dash, dcc, html, Input, Output, callback_context
from dash.exceptions import PreventUpdate

# Load available tickers from your stock_data folder
DATA_DIR = "stock_data"
# Ensure the directory exists
if not os.path.exists(DATA_DIR):
    os.makedirs(DATA_DIR)
    print(f"Created {DATA_DIR} directory. Please add .csv files.")

TICKERS = [f.split("_")[0] for f in os.listdir(DATA_DIR) if f.endswith(".csv")]

def load_data(ticker):
    path = f"{DATA_DIR}/{ticker}_historical.csv"
    if not os.path.exists(path):
        return pd.DataFrame() # Return empty if file not found
    df = pd.read_csv(path)
    df['DATE'] = pd.to_datetime(df['DATE'])
    return df

app = Dash(__name__)

app.layout = html.Div([
    html.H1("Market Data Dashboard", style={'textAlign': 'center'}),
    html.Div([
        html.Label("Select Ticker"),
        dcc.Dropdown(TICKERS, TICKERS[0] if TICKERS else None, id='ticker-dropdown')
    ], style={'width': '30%', 'display': 'inline-block'}),
    html.Div([
        html.Label("Select Date Range"),
        # Initialize with no dates, will be set by callback
        dcc.DatePickerRange(id='date-range', display_format='YYYY-MM-DD')
    ], style={'width': '40%', 'display': 'inline-block', 'paddingLeft': '20px'}),
    dcc.Graph(id='price-chart'),
    dcc.Graph(id='volume-chart'),
])

@app.callback(
    [Output('price-chart', 'figure'),
     Output('volume-chart', 'figure'),
     Output('date-range', 'start_date'),
     Output('date-range', 'end_date'),
     Output('date-range', 'min_date_allowed'),
     Output('date-range', 'max_date_allowed')],
    [Input('ticker-dropdown', 'value'),
     Input('date-range', 'start_date'),
     Input('date-range', 'end_date')]
)
def update_dashboard(ticker, start_date, end_date):
    if not ticker:
        raise PreventUpdate

    df = load_data(ticker)
    if df.empty:
        raise PreventUpdate

    # Get data min/max
    min_date = df['DATE'].min()
    max_date = df['DATE'].max()

    # Determine which input triggered the update
    ctx = callback_context
    trigger_id = ctx.triggered[0]['prop_id'].split('.')[0]

    # If it's the first load or ticker change, reset dates to max range
    if trigger_id == 'ticker-dropdown' or (start_date is None or end_date is None):
        start_date = min_date
        end_date = max_date

    # Filter data
    df = df[(df['DATE'] >= pd.to_datetime(start_date)) & 
            (df['DATE'] <= pd.to_datetime(end_date))]

    # Moving averages
    df['MA20'] = df['CLOSE'].rolling(20).mean()
    df['MA50'] = df['CLOSE'].rolling(50).mean()

    # Price chart
    price_fig = go.Figure()
    price_fig.add_trace(go.Scatter(x=df['DATE'], y=df['CLOSE'], name='Close'))
    price_fig.add_trace(go.Scatter(x=df['DATE'], y=df['MA20'], name='MA 20'))
    price_fig.add_trace(go.Scatter(x=df['DATE'], y=df['MA50'], name='MA 50'))
    price_fig.update_layout(title=f"{ticker} Price & Moving Averages", xaxis_title="Date", yaxis_title="Price")

    # Volume chart
    volume_fig = go.Figure()
    volume_fig.add_trace(go.Bar(x=df['DATE'], y=df['VOLUME'], name='Volume'))
    volume_fig.update_layout(title=f"{ticker} Volume", xaxis_title="Date", yaxis_title="Volume")

    return price_fig, volume_fig, start_date, end_date, min_date, max_date

if __name__ == '__main__':
    app.run_server(debug=True)
