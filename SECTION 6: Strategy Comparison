    report.append(f"Weight per stock: {1/len(eq_weights):.2%}")
    
    report.append("\n" + "="*80)
    report.append("STRATEGY 2: OPTIMIZED PORTFOLIO (MAX SHARPE RATIO)")
    report.append("="*80)
    report.append("\nAllocation: Weights optimized for maximum risk-adjusted returns")
    
