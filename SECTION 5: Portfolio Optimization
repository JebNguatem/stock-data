    plot_portfolio_performance(portfolio_values, returns_df)
    plot_cumulative_returns(portfolio_returns)
    plot_drawdown(portfolio_values)
    plot_returns_distribution(portfolio_returns)
    plot_metrics_summary(metrics)
    
    # Display key metrics
    print("\n" + "="*80)
